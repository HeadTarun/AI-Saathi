# Vercel frontend environment variables
#
# Recommended production setup:
# - Set BACKEND_URL only, so the browser calls this Vercel app and Next.js
#   rewrites /study/* and /health to the Render backend.
# - Leave NEXT_PUBLIC_API_URL empty unless you intentionally want direct
#   browser-to-Render API calls and have configured backend CORS for your domain.

BACKEND_URL=https://ai-saathi-1.onrender.com
# NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional Google login:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
